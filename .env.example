OPENAI_API_BASE=http://votre-serveur:8080/v1
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
MODEL_NAME=gtp-oss-120b
MODEL_CONTEXT_WINDOW=32000
GLOBAL_STATS="path-to-global-stats.json"
