VISION_MODEL_NAME=Qwen3-VL-32B-Instruct-FP8
VISION_CONTEXT_WINDOW=80000
# Base de données SQLite pour les sessions partagées
QUIZ_SESSIONS_DB=shared_data/quiz_sessions.db
